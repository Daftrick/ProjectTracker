    {
      "id": "versiones_blueprints",
      "label": "Flask Blueprints Architecture",
      "file_type": "rationale",
      "source_file": "VERSIONES.md",
      "source_location": "Blueprint projects_bp / quotes_bp / materials_bp / admin_bp",
      "source_url": null,
      "captured_at": null,
      "author": "Ricardo Flores Rivera",
      "contributor": null,
      "rationale": "Refactored from monolithic app.py into blueprints: projects_bp, quotes_bp, materials_bp, admin_bp. Legacy endpoint aliases registered in __init__.py to keep templates working."
    },
    {
      "id": "versiones_consistency_module",
      "label": "Consistency COT vs LDM Module",
      "file_type": "rationale",
      "source_file": "VERSIONES.md",
      "source_location": "Funcionalidades implementadas - Consistencia",
      "source_url": null,
      "captured_at": null,
      "author": "Ricardo Flores Rivera",
      "contributor": null,
      "rationale": "compute_consistency() selects most recent General COT, aggregates by catalog_item_id across all LDMs, computes margin % with ok/warning/critical thresholds at 30%/0%. Detects issues: missing_in_ldm, missing_in_cot, qty_mismatch, below_cost."
    },
    {
      "id": "versiones_bundles",
      "label": "Bundles Versioned System",
      "file_type": "rationale",
      "source_file": "VERSIONES.md",
      "source_location": "Funcionalidades implementadas - Bundles",
      "source_url": null,
      "captured_at": null,
      "author": "Ricardo Flores Rivera",
      "contributor": null,
      "rationale": "Manual versioned bundles that expand a commercial COT item into expected materials. comparison_rules define equivalence factors between COT and LDM items. comparison_ignored_items excludes items from cross-check while keeping them in project costs."
    },
    {
      "id": "versiones_audit_catalog",
      "label": "Deleted Catalog Audit System",
      "file_type": "rationale",
      "source_file": "VERSIONES.md",
      "source_location": "2026-05-03 entries",
      "source_url": null,
      "captured_at": null,
      "author": "Ricardo Flores Rivera",
      "contributor": null,
      "rationale": "When catalog items are deleted, deleted_catalog_item snapshot preserved in COT/LDM items. Three-action flow: preserve (keep reference), reconnect (link to new item), purge (remove permanently). Dedicated audit page /audit/deleted-catalog."
    },
    {
      "id": "versiones_drive_integration",
      "label": "Drive Integration (Multiplataforma)",
      "file_type": "rationale",
      "source_file": "VERSIONES.md",
      "source_location": "2026-04-28 drive entries + 2026-05-03 Drive v24.1",
      "source_url": null,
      "captured_at": null,
      "author": "Ricardo Flores Rivera",
      "contributor": null,
      "rationale": "config.json stores separate paths per OS (Windows/macOS/Linux). scan_drive_folder distinguishes error types: unconfigured/root_missing/folder_missing. Detects missing_base files. create_project_folder() auto-creates from UI."
    },
