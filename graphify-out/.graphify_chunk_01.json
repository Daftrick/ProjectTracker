    {
      "id": "csv_ref_catalogo",
      "label": "Catálogo Data Structure",
      "file_type": "document",
      "source_file": "REFERENCIA_ESTRUCTURAS_CSV.txt",
      "source_location": "MÓDULO 1",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "Ricardo Flores Rivera",
      "rationale": "Global reusable item registry independent of projects; serves as source for LDMs and COTs. ID generated by app (8-char hex). Prices can be zero (labor or unknown). Items linked to COT/LDM by catalog_item_id."
    },
    {
      "id": "csv_ref_ldm",
      "label": "Lista de Materiales (LDM) Data Structure",
      "file_type": "document",
      "source_file": "REFERENCIA_ESTRUCTURAS_CSV.txt",
      "source_location": "MÓDULO 2",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "Ricardo Flores Rivera",
      "rationale": "Per-project material lists sent to suppliers. Does not include sale prices. Legacy format LDM-{clave}-{MMDD}-{seq} coexists with current LDM-{clave}-{seq:02d}."
    },
    {
      "id": "csv_ref_cot",
      "label": "Cotización al Cliente (COT) Data Structure",
      "file_type": "document",
      "source_file": "REFERENCIA_ESTRUCTURAS_CSV.txt",
      "source_location": "MÓDULO 3",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "Ricardo Flores Rivera",
      "rationale": "Client-facing sales quotations with IVA. Quote number auto-generated as COT-{clave}-{G/P/E}{NN}-{YYYYMMDD}. Three types: General(G), Preliminar(P), Extraordinaria(E) with independent sequential counters."
    },
    {
      "id": "csv_ref_api_routes",
      "label": "CSV Import API Routes (Pending)",
      "file_type": "rationale",
      "source_file": "REFERENCIA_ESTRUCTURAS_CSV.txt",
      "source_location": "RUTAS DE API",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "POST /api/import/catalogo, /api/import/ldm, /api/import/cotizacion are pending implementation. Current APIs support single-item add, search, and bulk-delete on catalog."
    },
    {
      "id": "csv_ref_workflow_lisp",
      "label": "AutoCAD/LISP to App Workflow",
      "file_type": "rationale",
      "source_file": "REFERENCIA_ESTRUCTURAS_CSV.txt",
      "source_location": "WORKFLOW TÍPICO",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "LISP reads drawing, exports three CSV types (catalog, LDM, COT), app imports and assigns IDs, user reviews prices, generates PDFs for supplier and client."
    },
    {
      "id": "logica_projecttracker_core",
      "label": "ProjectTracker System Rationale",
      "file_type": "rationale",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 1",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": "Ricardo Flores Rivera",
      "rationale": "Local Flask app persisting JSON, no database, no internet. Design principles: full traceability from COT item to catalog to drawing; no duplication (one CSV per LDM); controlled changes via diff; scalable by discipline and project."
    },
    {
      "id": "logica_csv_plano",
      "label": "CSV de Plano (AutoCAD Export) Entity",
      "file_type": "document",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 3.4",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Filename pattern {CLAVE}-v{VER}-i{CONSEC}-{YYYYMMDD}.csv mandatory for app detection. Parser in drive.py:parse_csv_plano_filename. States: Pendiente/Actualización/Importado/Desactualizado tracked by decorate_csv_plano()."
    },
    {
      "id": "logica_proyecto_entity",
      "label": "Proyecto Entity",
      "file_type": "document",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 3.5",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Central entity linking all other entities. folder_num auto-incremental NNN; Drive folder IE-{folder_num:03d}-{clave}. Alcances track engineering scope completion with blocking dependencies."
    },
    {
      "id": "logica_import_diff",
      "label": "CSV→LDM Import Diff Algorithm",
      "file_type": "rationale",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 5.3",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Design for comparing old vs new CSV vs current LDM: Sin cambio/Actualizar/Revisar/Nuevo/Retirado actions. qty_editada flag tracks manual user modifications, preventing automated overwrite of manually adjusted quantities."
    },
    {
      "id": "logica_integridad_rules",
      "label": "Data Integrity Rules (R1-R7)",
      "file_type": "rationale",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 6",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "R1: One CSV per LDM. R2: qty_csv immutable after import. R3: manual rows invisible to diff. R4: no automatic row deletion. R5: LDM needs at least one row for PDF. R6: COT number sequential per type. R7: valid currencies MXN/USD/EUR."
    },
    {
      "id": "logica_scan_drive",
      "label": "scan_drive_folder Function",
      "file_type": "rationale",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 7",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Classifies drive files by prefix priority: csv_plano > ldm_files > cot_files > mem_files > ie_files > work_files > other_files. Decorates IE/MEM with highlight=True for most recent version."
    },
    {
      "id": "logica_catalog_hydration",
      "label": "Catalog Hydration Logic",
      "file_type": "rationale",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 8",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "catalog_maps() builds by_id and by_name dicts. resolve_catalog_binding() tries exact ID first, then normalized name. hydrate_quote/ldm adds catalog_linked, catalog_missing, calculates totals, groups items by section."
    },
    {
      "id": "logica_quote_sections",
      "label": "Quote Sections Feature",
      "file_type": "rationale",
      "source_file": "logica_cuantificaciones.txt",
      "source_location": "section 3.3",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Optional section grouping per item in COT. Items with same consecutive section value are grouped with subtotal. quote_section_groups() generates the structure. Rendered in form, view, and PDF."
    },
    {
      "id": "versiones_app_version",
      "label": "APP_VERSION Constant",
      "file_type": "rationale",
      "source_file": "VERSIONES.md",
      "source_location": "Fuente única de versión",
      "source_url": null,
      "captured_at": null,
      "author": "Ricardo Flores Rivera",
      "contributor": null,
      "rationale": "Single source of truth in tracker/domain.py. Injected to all templates via context processor in tracker/__init__.py. Versioning convention: decimal increments for UI/aesthetic changes, integer increments for new features."
    },
