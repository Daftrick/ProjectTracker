    },
    {
      "id": "team_member_entity",
      "label": "Team Member Entity",
      "file_type": "rationale",
      "source_file": "templates/team.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null
    },
    {
      "id": "bundle_entity",
      "label": "Bundle Entity (COT Commercial Item + LDM Components)",
      "file_type": "rationale",
      "source_file": "templates/bundles.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "A bundle maps one commercial quote item (COT) to multiple expected LDM material items with quantities and waste percentages, enabling technical consistency checks. Bundles have versioned component lists; only one version can be active at a time to participate in consistency analysis."
    },
    {
      "id": "comparison_rule_entity",
      "label": "COT/LDM Comparison Rule Entity",
      "file_type": "rationale",
      "source_file": "templates/comparison_rules.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Comparison rules handle cross-unit equivalences between COT and LDM items (e.g., tubing in ml on COT vs pieces on LDM). They define a factor, direction (LDM->COT or COT->LDM), rounding mode, and tolerance percentage."
    },
    {
      "id": "comparison_ignored_entity",
      "label": "Comparison Ignored Item Entity",
      "file_type": "rationale",
      "source_file": "templates/comparison_rules.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Items marked as ignored still count toward project cost but are excluded from COT/LDM discrepancy checking. Scope can be commercial-only, technical-only, or both."
    },
    {
      "id": "google_drive_integration",
      "label": "Google Drive Integration Settings",
      "file_type": "rationale",
      "source_file": "templates/settings.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Drive paths are stored per OS (Windows/macOS) so the same shared folder can be accessed from different machines without configuration conflicts."
    },
