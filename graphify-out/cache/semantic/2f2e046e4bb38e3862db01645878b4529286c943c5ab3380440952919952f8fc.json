{"nodes": [{"id": "quote_project_form_template", "label": "Quote Project Form Template (Advanced)", "file_type": "code", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "quote_sections_pattern", "label": "Quote Sectioned Line Items Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sections allow grouping quote line items (partidas) with per-section subtotals, enabling structured breakdowns for complex projects. Items belong to a section via a hidden field that is synced on drag-and-drop reorder and on form submit."}, {"id": "quote_bulk_actions_pattern", "label": "Quote Bulk Row Selection & Actions Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-select checkboxes on quote rows with a floating action toolbar allow users to move, copy, or delete many rows at once without repeated single-row operations."}, {"id": "inline_autocomplete_catalog_pattern", "label": "Inline Catalog Autocomplete Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Typing in any item description field fires a debounced /api/catalogo query and shows a dropdown (ac-dropdown). This avoids a full page reload to link items to the catalog and reduces data entry errors."}, {"id": "deleted_catalog_item_pattern", "label": "Deleted Catalog Item Handling Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When a catalog item referenced by a quote/LDM row is deleted, the row is highlighted and offers three actions: preserve historically (keep reference but mark resolved), reconnect (link to a new catalog item), or purge (remove the row). Snapshot data of the deleted item is stored as hidden fields to maintain traceability."}, {"id": "drag_reorder_rows_pattern", "label": "Drag-and-Drop Row Reorder Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Mouse-based drag handles on table rows allow reordering quote and LDM line items without requiring numbered inputs. After drop, syncItemSections() updates hidden section fields to reflect new positions."}, {"id": "fixed_bottom_bar_pattern", "label": "Fixed Bottom Summary Bar Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A position:fixed bottom bar shows live subtotal, IVA, and total while the user scrolls through a long items table, preventing the need to scroll up to see totals."}, {"id": "sticky_table_header_pattern", "label": "Sticky Table Header with Dynamic Offset Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "syncStickyItemsOffsets() reads the topbar and card header heights at runtime and sets CSS variables (--sticky-items-toolbar-top, --sticky-items-head-top) so that sticky thead and card-header do not overlap the fixed topbar at any window size."}, {"id": "partida_filter_pattern", "label": "Client-side Partida Filter Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rows are hidden/shown in-place (display:none) rather than removed from the DOM so the form still submits all items on save regardless of filter state."}, {"id": "quote_number_autogen_pattern", "label": "Auto-generated Quote Number Pattern", "file_type": "rationale", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The server pre-computes base numbers (NUM_G, NUM_P, NUM_E) per quote type. Changing the date or type in the form updates the number field client-side by substituting the 8-digit date portion. A userEditedNum flag prevents auto-update after manual edits."}, {"id": "api_catalogo_endpoint", "label": "API Endpoint /api/catalogo", "file_type": "code", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "api_catalogo_add_endpoint", "label": "API Endpoint /api/catalogo/add", "file_type": "code", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "quotes_bp_preserve_deleted", "label": "Endpoint quotes_bp.preserve_deleted_item", "file_type": "code", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "quotes_bp_restore_deleted", "label": "Endpoint quotes_bp.restore_deleted_item", "file_type": "code", "source_file": "templates/quote_project_form.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "quotes_bp_purge_deleted", "label": "Endpoint quotes_bp.purge_deleted_item", "file_type": "code", "source_file": "templates/quote_project_form.html", "source_location": null, 