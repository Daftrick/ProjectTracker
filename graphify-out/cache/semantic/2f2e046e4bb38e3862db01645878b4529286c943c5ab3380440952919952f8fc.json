_entity", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "templates/quote_project_form.html", "source_location": "line 490", "weight": 1.0}, {"source": "quote_entity", "target": "catalog_item_entity", "relation": "shares_data_with", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "templates/quote_project_form.html", "source_location": null, "weight": 1.0}, {"source": "inline_autocomplete_catalog_pattern", "target": "partida_filter_pattern", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "templates/quote_project_form.html", "source_location": null, "weight": 0.65}, {"source": "quote_project_form_template", "target": "ldm_form_template", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "templates/quote_project_form.html", "source_location": null, "weight": 0.85}, {"source": "fixed_bottom_bar_pattern", "target": "sticky_table_header_pattern", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "templates/quote_project_form.html", "source_location": null, "weight": 0.75}], "hyperedges": [{"id": "quote_form_ux_patterns", "label": "Quote Form UX Patterns (Drag, Filter, Autocomplete, Fixed Bar, Sticky Header)", "nodes": ["drag_reorder_rows_pattern", "partida_filter_pattern", "inline_autocomplete_catalog_pattern", "fixed_bottom_bar_pattern", "sticky_table_header_pattern"], "relation": "form", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "templates/quote_project_form.html"}]}